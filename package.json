{
  "name": "assessment",
  "homepage": "https://brona90.github.io/assessment",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "cucumber": "node node_modules/@cucumber/cucumber/bin/cucumber.js --parallel 5",
    "build:singlefile": "vite build --config vite.singlefile.config.js && mv dist-singlefile/index.html dist-singlefile/assessment.html",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "size": "size-limit",
    "size:check": "size-limit --limit"
  },
  "size-limit": [
    {
      "name": "Initial bundle (excludes lazy-loaded PDF/Excel/canvas)",
      "path": [
        "dist/**/*.js",
        "!dist/**/jspdf*",
        "!dist/**/excel*",
        "!dist/**/html2canvas*"
      ],
      "limit": "250 kB",
      "gzip": true
    }
  ],
  "dependencies": {
    "chart.js": "^4.5.1",
    "exceljs": "^4.4.0",
    "idb": "^8.0.3",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.577.0",
    "prop-types": "^15.8.1",
    "react": "^19.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@babel/register": "^7.28.3",
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@cucumber/cucumber": "^12.2.0",
    "@eslint/js": "^9.39.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.56.1",
    "@size-limit/file": "^12.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/coverage-v8": "^4.0.9",
    "@vitest/ui": "^4.0.9",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "gh-pages": "^6.3.0",
    "globals": "^16.5.0",
    "jsdom": "^27.2.0",
    "playwright": "^1.56.1",
    "size-limit": "^12.0.1",
    "vite": "^7.2.2",
    "vite-plugin-singlefile": "^2.3.0",
    "vitest": "^4.0.9",
    "vitest-axe": "^0.1.0"
  }
}
